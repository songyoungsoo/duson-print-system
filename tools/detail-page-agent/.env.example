# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-pro
GEMINI_FALLBACK_MODEL=gemini-2-flash

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Database Configuration (Optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/detail_page_agents

# Redis Configuration (Optional - for caching)
# REDIS_URL=redis://localhost:6379/0

# Vector DB Configuration (Optional)
# PINECONE_API_KEY=your_pinecone_api_key
# PINECONE_ENVIRONMENT=us-west-1

# Web Scraping Configuration
# SERPER_API_KEY=your_serper_api_key  # For Google Search API
# MAX_CONCURRENT_REQUESTS=5

# Caching Configuration
# CACHE_ENABLED=true
# CACHE_TTL=3600

# Rate Limiting (Optional)
# RATE_LIMIT_PER_MINUTE=60

# CORS Configuration
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Image Generation (Optional)
# STABILITY_API_KEY=your_stability_api_key
# OPENAI_API_KEY=your_openai_api_key
